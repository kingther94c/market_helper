# To store this file outside the repo:
#   - Set MARKET_HELPER_GDRIVE_ROOT in your shell profile (see below); the
#     code auto-uses <ROOT>/local.env. This is the recommended setup if the
#     same local.env lives at the GDrive root that already hosts mirrored
#     reports.
#   - Or set MARKET_HELPER_CONFIG_PATH directly to the env file path.
# If neither is set (or the path doesn't resolve to a file), tools fall back
# to this checked-in local.env.
ALPHA_VANTAGE_API_KEY="your_alpha_vantage_api_key"
DEFAULT_PROD_ACCOUNT_ID="your_prod_account_id"
DEFAULT_DEV_ACCOUNT_ID="your_dev_or_paper_account_id"
IBKR_FLEX_QUERY_ID="your_ibkr_flex_query_id"
IBKR_FLEX_TOKEN="your_ibkr_flex_token"
# Optional: artifact-mirror destination (e.g. a Google Drive sync folder).
# Resolved in this priority order; first hit wins:
#
#   1. MARKET_HELPER_GOOGLE_DRIVE_DIR  — single full path to the leaf folder.
#      Simplest if you only ever set it in your shell profile.
#   2. MARKET_HELPER_GDRIVE_ROOT  + MARKET_HELPER_REPORT_SUBDIR  — joined.
#      SUBDIR defaults to "Portfolio_Report". Useful when this local.env is
#      itself synced via GDrive (one file, two machines) so the per-machine
#      ROOT is set in each shell profile instead.
#   3. artifact_mirror.google_drive_dir in report_config.yaml (back-compat).
#
# Examples (set in your shell profile, not here, since paths differ per host):
#   macOS .zshrc:
#     export MARKET_HELPER_GDRIVE_ROOT="/Users/<you>/Library/CloudStorage/GoogleDrive-<email>/My Drive/005 Portfolio"
#   Windows PowerShell $PROFILE:
#     $env:MARKET_HELPER_GDRIVE_ROOT = "G:/My Drive/005 Portfolio"
#
# Reports then land in <ROOT>/Portfolio_Report/ on each machine.
# MARKET_HELPER_REPORT_SUBDIR="Portfolio_Report"
# MARKET_HELPER_GOOGLE_DRIVE_DIR=""
