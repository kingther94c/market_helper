# Default: let git decide based on content.
* text=auto

# Shell scripts must stay LF on disk so bash can execute them — `\r` in
# `#!/usr/bin/env bash` would be parsed as part of the interpreter path.
*.sh        text eol=lf

# Windows batch files must stay CRLF so cmd.exe parses them correctly
# (some constructs misbehave under LF-only line endings).
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# Data assets we don't want git to mangle.
*.feather   binary
*.xlsx      binary
*.xlsm      binary
*.pdf       binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.parquet   binary
